<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Analisador de Performance • Clube Multi Trader</title>

  <link rel="icon" href="/clube-multi-trader-site/favicon.ico" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Playfair+Display:wght@700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/clube-multi-trader-site/assets/style.css" />

  <style>
    .analise-container{
      max-width: 900px;
      margin: 40px auto;
      padding: 20px;
    }

    .analise-form label{
      display: block;
      margin-top: 18px;
      font-weight: 600;
    }

    .analise-form input{
      width: 100%;
      padding: 10px;
      margin-top: 6px;
      border-radius: 6px;
      border: 1px solid rgba(255,255,255,.15);
      background: rgba(255,255,255,.05);
      color: #fff;
    }

    .analise-btn{
      margin-top: 28px;
      display: inline-block;
      padding: 12px 22px;
      background: #d4af37;
      color: #000;
      font-weight: 700;
      border-radius: 6px;
      cursor: pointer;
      transition: .2s;
    }

    .analise-btn:hover{
      background: #f5d76e;
    }

    .resultado-card{
      margin-top: 40px;
      padding: 24px;
      border-radius: 10px;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.12);
      line-height: 1.6;
    }

    .resultado-card p{
      margin-bottom: 10px;
    }
  </style>
</head>

<body>

  <!-- NAV -->
  <nav>
    <div class="nav-content">
      <div class="logo">⚜️ CLUBE MULTI TRADER</div>

      <ul class="nav-links">
        <li><a href="/clube-multi-trader-site/">Início</a></li>
        <li><a href="/clube-multi-trader-site/cursos/">Cursos</a></li>
        <li><a href="/clube-multi-trader-site/materiais/">Materiais</a></li>
        <li><a href="/clube-multi-trader-site/blog/">Blog</a></li>
        <li><a href="/clube-multi-trader-site/calendario/">Calendário</a></li>
        <li><a href="/clube-multi-trader-site/contato/">Contato</a></li>
      </ul>

      <button class="nav-toggle" id="navToggle" aria-label="Abrir menu">
        <span></span>
      </button>
    </div>

    <div class="nav-mobile" id="navMobile">
      <ul>
        <li><a href="/clube-multi-trader-site/">Início</a></li>
        <li><a href="/clube-multi-trader-site/cursos/">Cursos</a></li>
        <li><a href="/clube-multi-trader-site/materiais/">Materiais</a></li>
        <li><a href="/clube-multi-trader-site/blog/">Blog</a></li>
        <li><a href="/clube-multi-trader-site/calendario/">Calendário</a></li>
        <li><a href="/clube-multi-trader-site/contato/">Contato</a></li>
      </ul>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-badge">📊</div>
      <h1 class="hero-title">Analisador de Performance do Trader</h1>
      <p class="hero-subtitle">Preencha seus dados e receba uma análise automática baseada em métricas profissionais</p>
    </div>
  </section>

  <!-- FORMULÁRIO -->
  <section>
    <div class="analise-container">

      <h2 class="section-title">Preencha seus resultados</h2>

      <form class="analise-form">

        <label>Lucro líquido total ($):</label>
        <input type="number" id="lucro" step="0.01">

        <label>Número total de trades:</label>
        <input type="number" id="trades">

        <label>Taxa de acerto (%):</label>
        <input type="number" id="acerto" step="0.01">

        <label>Maior ganho ($):</label>
        <input type="number" id="maiorGanho" step="0.01">

        <label>Maior perda ($):</label>
        <input type="number" id="maiorPerda" step="0.01">

        <div class="analise-btn" onclick="analisar()">Gerar Análise</div>
      </form>

      <div id="resultado" class="resultado-card" style="display:none;"></div>

    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-content">
      <p class="footer-text">© 2021 Clube Multi Trader. Todos os direitos reservados.</p>
      <a href="https://www.litefinance.org/?uid=929590812&_ptid=%7Bkpdx%7DH4sIAAAAAAAAAytJzEvMzSlWSKnMS8zLTC0qqSxIVSjJV0jOTU0uyczPU0jNS07MSU0BAHdJ-80qAAAA"
         target="_blank" rel="noopener noreferrer" class="footer-link">
        🔗 Acesse LiteFinance
      </a>
    </div>
  </footer>

  <script>
    function analisar() {
      const lucro = parseFloat(document.getElementById('lucro').value || 0);
      const trades = parseInt(document.getElementById('trades').value || 0);
      const acerto = parseFloat(document.getElementById('acerto').value || 0);
      const maiorGanho = parseFloat(document.getElementById('maiorGanho').value || 0);
      const maiorPerda = parseFloat(document.getElementById('maiorPerda').value || 0);

      let analise = "<h3 style='margin-bottom:12px;'>📈 Resultado da Análise</h3>";

      if (lucro > 0) analise += "<p>✅ Você está lucrativo no período analisado.</p>";
      else analise += "<p>⚠ Você está negativo no período analisado.</p>";

      if (acerto >= 70) analise += "<p>✅ Sua taxa de acerto é boa.</p>";
      else analise += "<p>⚠ Sua taxa de acerto está baixa. Reveja seus filtros de entrada.</p>";

      if (Math.abs(maiorPerda) > maiorGanho)
        analise += "<p>⚠ Sua maior perda é maior que seu maior ganho. Risco assimétrico contra você.</p>";
      else
        analise += "<p>✅ Seu maior ganho é maior que sua maior perda. Boa assimetria.</p>";

      if (trades > 20)
        analise += "<p>⚠ Volume alto de trades. Cuidado com overtrading.</p>";
      else if (trades > 0)
        analise += "<p>✅ Quantidade de trades saudável.</p>";

      document.getElementById('resultado').style.display = "block";
      document.getElementById('resultado').innerHTML = analise;
    }
  </script>

  <script src="/clube-multi-trader-site/assets/main.js"></script>
</body>
</html>
